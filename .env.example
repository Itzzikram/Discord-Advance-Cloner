# Discord Bot Token (User Account Token for selfbot)
DISCORD_TOKEN=your_discord_token_here

# Source Guild ID (the server to clone from)
SOURCE_GUILD_ID=123456789012345678

# Target Guild ID (the server to clone to)
TARGET_GUILD_ID=987654321098765432

# Cloner Settings
CLONE_GUILDS=true
CLONE_CHANNELS=true
CLONE_ROLES=true
CLONE_MEMBERS=false
CLONE_MESSAGES=false
CLONE_EMOJIS=false
CLONE_WEBHOOKS=true
CLONE_THREADS=false

# Optional: Message Limit (when CLONE_MESSAGES=true)
MESSAGE_LIMIT=50

# Optional: Proxy Configuration
PROXY_HOST=localhost
PROXY_PORT=8080

# Optional: Logging
LOG_LEVEL=info
